#!/usr/bin/env bash

# Starts the ReactiveView daemon orchestrator.
#
# Run this in a separate terminal from `bin/dev` during development.

set -euo pipefail

if [ ! -d ".reactive_view" ]; then
  echo "Setting up ReactiveView..."
  bin/rails reactive_view:setup
fi

echo "Starting ReactiveView dev orchestrator..."
exec bundle exec reactiveview dev "$@"

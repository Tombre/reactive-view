#!/usr/bin/env bash

# Starts the ReactiveView daemon orchestrator.
#
# `bin/dev` already starts this via Procfile.dev.
# Run this directly only when you are starting Rails separately with `bin/web`.

set -euo pipefail

if [ ! -d ".reactive_view" ]; then
  echo "Setting up ReactiveView..."
  bin/rails reactive_view:setup
fi

echo "Starting ReactiveView dev orchestrator..."

echo "Running ReactiveView doctor --fix preflight..."
bundle exec reactiveview doctor --fix || true

exec bundle exec reactiveview dev "$@"

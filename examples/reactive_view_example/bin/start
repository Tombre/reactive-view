#!/usr/bin/env bash

set -euo pipefail

APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$APP_ROOT"

if ! command -v bundle >/dev/null 2>&1; then
  echo "Bundler is not installed. Install it with: gem install bundler" >&2
  exit 1
fi

echo "Ensuring Ruby gems are installed..."
if ! bundle check >/dev/null 2>&1; then
  bundle install
fi

if [ ! -d ".reactive_view" ]; then
  echo "Running ReactiveView setup..."
  bin/rails reactive_view:setup
fi

echo "Syncing ReactiveView files..."
bin/rails reactive_view:sync 2>/dev/null || true

echo "Preparing database..."
bin/rails db:prepare

echo "Starting ReactiveView example (Rails + daemon)..."

bin/dev "$@" &
web_pid=$!

bin/reactive-view-dev &
daemon_pid=$!

cleanup() {
  for pid in "$web_pid" "$daemon_pid"; do
    if kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
    fi
  done

  wait "$web_pid" 2>/dev/null || true
  wait "$daemon_pid" 2>/dev/null || true
}

trap cleanup INT TERM EXIT

exit_status=0

while true; do
  if ! kill -0 "$web_pid" 2>/dev/null; then
    wait "$web_pid" || exit_status=$?
    break
  fi

  if ! kill -0 "$daemon_pid" 2>/dev/null; then
    wait "$daemon_pid" || exit_status=$?
    break
  fi

  sleep 1
done

exit "$exit_status"
